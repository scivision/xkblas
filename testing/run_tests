#!/bin/bash


# Global variables
PRECISION="z c d s"
BS="128"
N="1024"
NGPU=1
KILLDELAY=10m

#run each kernel
run_GEMM()
{
  p=$1
  n=$2
  b=$3
  echo KAAPI_NUM_GPUS=$NGPU KAAPI_VERBOSE=1 LD_LIBRARY_PATH=.:$LD_LIBRARY_PATH ./testing_$p 0 1 $b $b GEMM 0.32 0.12 $n $n $n $n $n $n 1
  KAAPI_NUM_GPUS=$NGPU KAAPI_VERBOSE=1 LD_LIBRARY_PATH=.:$LD_LIBRARY_PATH timeout --signal=KILL $KILLDELAY ./testing_$p 0 1 $b $b GEMM 0.32 0.12 $n $n $n $n $n $n 1
}


#ifndef __XKBLAS_SUPPORT_H__
# define __XKBLAS_SUPPORT_H__

# define XKBLAS_SUPPORT_CBLAS   @USE_CBLAS@

# define XKBLAS_SUPPORT_CUDA    @USE_CUDA@
# define XKBLAS_SUPPORT_CUBLAS  @USE_CUBLAS@

# define XKBLAS_SUPPORT_HIP     @USE_HIP@
# define XKBLAS_SUPPORT_HIPBLAS @USE_HIPBLAS@

# define XKBLAS_SUPPORT_CLBLAST @USE_CLBLAST@

# define XKBLAS_SUPPORT_ZE      @USE_ZE@

# define XKBLAS_SUPPORT_SYCL    @USE_SYCL@

# include <xkrt/support.h>
# if (XKBLAS_SUPPORT_CUDA || XKBLAS_SUPPORT_CUBLAS) && !XKRT_SUPPORT_CUDA
#  pragma error "XKBlas build with CUDA support while XKRT was not"
# endif

# if (XKBLAS_SUPPORT_HIP || XKBLAS_SUPPORT_HIPBLAS) && !XKRT_SUPPORT_HIP
#  pragma error "XKBlas build with HIP support while XKRT was not"
# endif

#endif /* __XKBLAS_SUPPORT_H__ */
